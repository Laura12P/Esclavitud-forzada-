--- CICLO 1: Restricciones De PRIMARY KEY
ALTER TABLE Punto
  ADD CONSTRAINT pk_punto_nombre
  PRIMARY KEY (nombre);

ALTER TABLE Carrera
  ADD CONSTRAINT pk_carrera_codigo
  PRIMARY KEY (Codigo);

ALTER TABLE Segmento
  ADD CONSTRAINT pk_segmento_nombre
  PRIMARY KEY (nombre);

ALTER TABLE PropiedadDe
  ADD CONSTRAINT pk_propiedadDe_idParticipante_CodigoCarrera
  PRIMARY KEY (idParticipante, codigoCarrera);

ALTER TABLE Version
  ADD CONSTRAINT pk_version_nombre
  PRIMARY KEY (nombre);

ALTER TABLE Organizacion
    ADD CONSTRAINT pk_organizacion_idParticipante_nombreVersion
    PRIMARY KEY (idParticipante, nombreVersion);
 
ALTER TABLE Participacion
    ADD CONSTRAINT pk_participacion_idParticipante_nombreVersion
    PRIMARY KEY (idParticipante, nombreVersion);
 
ALTER TABLE AgrupacionSegmento
    ADD CONSTRAINT pk_agrupacionSegmento_nombreVersion_nombreSegmento
    PRIMARY KEY (nombreVersion, nombreSegmento);
 
ALTER TABLE Participante
