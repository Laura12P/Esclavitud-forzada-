    PRIMARY KEY (id);
 
ALTER TABLE Persona
    ADD CONSTRAINT pk_persona_idParticipante
    PRIMARY KEY (idParticipante);
 
ALTER TABLE Ciclista
    ADD CONSTRAINT pk_ciclista_idParticipante
    PRIMARY KEY (idParticipante);
 
ALTER TABLE Empresa
