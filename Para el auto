
-- Tabla padre: TRoomType
CREATE TABLE TRoomType (
    room_type_id  NUMBER(11)    NOT NULL,
    id            VARCHAR2(6)   NOT NULL,
    description   VARCHAR2(100)
);
 
-- Tabla padre: TRate (precios por tipo de habitación y ocupación)
CREATE TABLE TRate (
    room_type_id  NUMBER(11)   NOT NULL,
    occupancy     NUMBER(11)   NOT NULL,
    amount        NUMBER(10,2) NOT NULL
);
 
-- Tabla hijo: TRoom
CREATE TABLE TRoom (
    room_id       NUMBER(3)    NOT NULL,
    room_type_id  NUMBER(11)   NOT NULL,
    max_occupacy  NUMBER(11)   NOT NULL
);
-- CK_ROOM_ID: room_id debe estar entre 101 y 999, sin múltiplos de 100
ALTER TABLE TRoom ADD CONSTRAINT CK_ROOM_ID
    CHECK (room_id BETWEEN 101 AND 999 AND MOD(room_id, 100) != 0);
    
-- CK_ROOM_MAX_OCCUPACY: max_occupacy debe ser >= 1
ALTER TABLE TRoom ADD CONSTRAINT CK_ROOM_MAX_OCCUPACY
    CHECK (max_occupacy >= 1);
 
-- CK_RATE_OCCUPANCY: la ocupación en TRate debe ser >= 1
ALTER TABLE TRate ADD CONSTRAINT CK_RATE_OCCUPANCY
    CHECK (occupancy >= 1);
 
-- CK_RATE_AMOUNT: el precio debe ser mayor que 0
ALTER TABLE TRate ADD CONSTRAINT CK_RATE_AMOUNT
    CHECK (amount > 0);
    
-- PK de TRoomType
ALTER TABLE TRoomType ADD CONSTRAINT PK_ROOM_TYPE
    PRIMARY KEY (room_type_id);
 
-- PK de TRate (tipo de habitación + ocupación forman la clave)
ALTER TABLE TRate ADD CONSTRAINT PK_RATE
    PRIMARY KEY (room_type_id, occupancy);
 
-- PK de TRoom
ALTER TABLE TRoom ADD CONSTRAINT PK_ROOM
    PRIMARY KEY (room_id);
 
-- FK de TRate → TRoomType
ALTER TABLE TRate ADD CONSTRAINT FK_RATE_ROOM_TYPE
    FOREIGN KEY (room_type_id) REFERENCES TRoomType(room_type_id);
 
