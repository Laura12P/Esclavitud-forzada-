-- XTablas: Eliminar la tabla si existe
DROP TABLE TRoom CASCADE CONSTRAINTS;

-- Tablas: Crear la tabla
CREATE TABLE TRoom (
    room_id       NUMBER(3)    NOT NULL,
    room_type_id  NUMBER(11)   NOT NULL,
    max_occupacy  NUMBER(11)   NOT NULL
);

-- CK_ROOM_ID: id entre 101 y 999, sin múltiplos de 100
ALTER TABLE TRoom ADD CONSTRAINT CK_ROOM_ID
    CHECK (room_id BETWEEN 101 AND 999 AND MOD(room_id, 100) != 0);

-- CK_ROOM_MAX_OCCUPACY: max_occupacy debe ser >= 1
ALTER TABLE TRoom ADD CONSTRAINT CK_ROOM_MAX_OCCUPACY
    CHECK (max_occupacy >= 1);

-- CK_ROOM_ID_MAX_OCCUPACY: cuartos del primer piso máximo 2 ocupantes
ALTER TABLE TRoom ADD CONSTRAINT CK_ROOM_ID_MAX_OCCUPACY
    CHECK (NOT (FLOOR(room_id / 100) = 1 AND max_occupacy > 2));

-- PK_ROOM: clave primaria
ALTER TABLE TRoom ADD CONSTRAINT PK_ROOM
    PRIMARY KEY (room_id);

-- FK_ROOM_ROOM_TYPE: clave foránea hacia TRoomType
ALTER TABLE TRoom ADD CONSTRAINT FK_ROOM_ROOM_TYPE
    FOREIGN KEY (room_type_id) REFERENCES TRoomType(room_type_id);

-- OK: id válido, max_occupacy válido
INSERT INTO TRoom VALUES (301, 1, 3);  -- id no múltiplo de 100, occupacy >= 1
INSERT INTO TRoom VALUES (999, 1, 5);  -- id en límite superior válido
INSERT INTO TRoom VALUES (101, 1, 1);  -- piso 1, occupacy = 1 
INSERT INTO TRoom VALUES (102, 1, 2);  -- piso 1, occupacy = 2 (límite permitido)


