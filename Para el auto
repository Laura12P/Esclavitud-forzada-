-- ============================================================
-- Disparadores: Creación
-- ============================================================

-- TR_ROOM_BI: Disparador BEFORE INSERT sobre TRoom
-- Automatiza: si max_occupacy es NULL, asigna el MAX(occupancy) de TRate para ese tipo
-- Restringe: no permite insertar si el tipo de habitación no tiene precios en TRate
CREATE OR REPLACE TRIGGER TR_ROOM_BI
BEFORE INSERT ON TRoom
FOR EACH ROW
DECLARE
    v_count        NUMBER;
    v_max_occupacy TRate.occupancy%TYPE;
BEGIN
    -- Verificar que el tipo de habitación tiene precios asignados
    SELECT COUNT(*)
      INTO v_count
      FROM TRate
     WHERE room_type_id = :NEW.room_type_id;

    IF v_count = 0 THEN
        RAISE_APPLICATION_ERROR(
            -20001,
            'No se puede crear la habitación: el tipo de habitación no tiene precios asignados.'
        );
    END IF;

    -- Si no se indicó max_occupacy, se asigna la ocupación máxima definida en TRate
    IF :NEW.max_occupacy IS NULL THEN
        SELECT MAX(occupancy)
          INTO v_max_occupacy
          FROM TRate
         WHERE room_type_id = :NEW.room_type_id;

        :NEW.max_occupacy := v_max_occupacy;
    END IF;
END TR_ROOM_BI;
/

-- TR_ROOM_BU: Disparador BEFORE UPDATE sobre TRoom
-- Restringe: solo se puede modificar max_occupacy, y únicamente puede aumentar
CREATE OR REPLACE TRIGGER TR_ROOM_BU
BEFORE UPDATE ON TRoom
FOR EACH ROW
BEGIN
    -- Solo max_occupacy puede cambiar; room_id no debe modificarse
    IF :NEW.room_id != :OLD.room_id THEN
        RAISE_APPLICATION_ERROR(
            -20002,
            'No se permite modificar el identificador de la habitación (room_id).'
        );
    END IF;

    -- room_type_id no debe modificarse
    IF :NEW.room_type_id != :OLD.room_type_id THEN
        RAISE_APPLICATION_ERROR(
            -20003,
            'No se permite modificar el tipo de habitación (room_type_id).'
        );
    END IF;

    -- max_occupacy únicamente puede aumentar (no se permite igual ni menor)
    IF :NEW.max_occupacy <= :OLD.max_occupacy THEN
        RAISE_APPLICATION_ERROR(
            -20004,
            'La máxima ocupación solo puede aumentar. Valor nuevo debe ser mayor al actual (' 
            || :OLD.max_occupacy || ').'
        );
    END IF;
END TR_ROOM_BU;
/


